# ────────────────────────────────────────────────────────────────
# iClaw-cloud configuration.
#
# Copy this file to `.env` and adjust. Every value is validated at
# boot time in `src/config.ts` — invalid values fail fast.
# ────────────────────────────────────────────────────────────────

# Node lifecycle mode: development | production | test
NODE_ENV=development

# Public origin of this server. Used to build share URLs.
BASE_URL=http://localhost:4000

# HTTP listen port.
PORT=4000

# ─── MongoDB ─────────────────────────────────────────────────────
# Mongo connection URI (see docker-compose.yml for a local setup).
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=iclaw_cloud

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for POST /api/shares.
# Use "*" for dev (NEVER in production).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── Limits ──────────────────────────────────────────────────────
# Max ciphertext payload per share, in bytes (default 5 MiB).
MAX_PAYLOAD_BYTES=5242880

# Per-IP create-share rate limit (default 20 / hour).
RATE_LIMIT_PER_IP_HOUR=20

# Per-IP read rate limit (default 60 / minute).
READ_RATE_LIMIT_PER_IP_MINUTE=60

# Min / max allowed TTL in days. Clients must pick within this range.
TTL_MIN_DAYS=1
TTL_MAX_DAYS=30

# ─── Operational ─────────────────────────────────────────────────
# Log create/read/delete events (id, ip-hash, size). Never logs ciphertext.
LOG_ACCESS=true

# Trust the first proxy hop's X-Forwarded-For — enable when running
# behind Cloudflare, nginx, etc. so rate-limiting keys off the real IP.
TRUST_PROXY=false
